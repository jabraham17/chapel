echo_and_run mason clean

# not built
echo_and_run mason run --example example.chpl || echo "exited with $?"

# no --build
echo_and_run mason run --example example.chpl --force || echo "exited with $?"

# no --build
echo_and_run mason run --example example.chpl --no-update || echo "exited with $?"

# unknown
echo_and_run mason build --example Unknown || echo "exited with $?"
echo_and_run mason run --example Unknown || echo "exited with $?"
