echo_and_run mason init testing-pkg/foo-bar --name foo-bar || echo "expected failure for invalid package name"
rm -rf testing-pkg


rm -rf testingPkg && mkdir testingPkg && cd testingPkg
git init -b main
echo_and_run mason init || echo "expected failure for existing mason package"
rm -rf .git
echo "foo" > .gitignore
echo 'MASON_LOG_LEVEL=warn mason init'
MASON_LOG_LEVEL=warn mason init | grep ".gitignore already exists"
echo_and_run cat .gitignore
echo_and_run cat Mason.toml | sed '/chplVersion/d'
