echo_and_run mason init testingPkg --name foobar || echo "expected failure for existing mason package"


rm -rf testingPkg && mkdir testingPkg && cd testingPkg
echo_and_run mason init --no-vcs
echo_and_run mason init --no-vcs || echo "expected failure for existing mason package"
cd ..


